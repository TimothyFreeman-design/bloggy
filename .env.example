# Copy this file to .env and replace the values with your own secure admin credentials.
# Do not commit your real admin password or hash.

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<your-bcrypt-hash>
SESSION_SECRET=replace-with-a-long-random-secret
FRONTEND_ORIGIN=http://localhost:5173

# If the frontend and backend run on different origins, set this value:
VITE_API_BASE_URL=http://localhost:5174

# To generate a bcrypt password hash, you can use the included script after installing dependencies:
#   npm install
#   npm run hash-password "YourStrongPassword"
# A strong password should be long, unique, and include letters, numbers, and symbols.
